# ===========================================
# Sofia Voice Agent — Environment (Chile + Supabase)
# ===========================================
# Copia como .env y rellena.

# --- Retell AI (Agente de Voz) ---
RETELL_API_KEY=
RETELL_OUTBOUND_AGENT_ID=

# --- Twilio (Telefonía Chile +56) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Telnyx (segundo carrier opcional, más barato CL) ---
TELNYX_PHONE_NUMBER=

# --- Routing multi-carrier ---
# PRIMARY_CARRIER:  twilio | telnyx
# FALLBACK_CARRIER: twilio | telnyx | (vacío = sin failover)
# Hoy: solo Twilio. Cuando Telnyx esté aprobado: PRIMARY=telnyx, FALLBACK=twilio.
PRIMARY_CARRIER=twilio
FALLBACK_CARRIER=

# --- Supabase self-hosted (CRM + Auth de la webapp) ---
SUPABASE_URL=https://spbsagtimb.cesmark.cl
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# --- Modal (Hosting backend) ---
# Modal usa autenticación vía CLI: `modal token new`
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=

# --- Anthropic (Resúmenes post-llamada) ---
ANTHROPIC_API_KEY=
